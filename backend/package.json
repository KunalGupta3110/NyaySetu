{
  "name": "nyaysetu-legal-ai",
  "version": "2.0.0",
  "description": "NyaySetu - High-Reliability Indian Legal AI System with RAG",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "index:legal-kb": "node scripts/index-legal-kb.js",
    "init:rag": "node scripts/init-rag.js",
    "setup": "npm install && node scripts/setup.js",
    "ingest:real-data": "node scripts/init-real-data.js",
    "ingest:ecourt": "node -e \"const DataIngestionPipeline = require('./scripts/data-ingestion-pipeline'); new DataIngestionPipeline().ingestRealData({ sources: ['ecourt'] })\"",
    "ingest:supreme-court": "node -e \"const DataIngestionPipeline = require('./scripts/data-ingestion-pipeline'); new DataIngestionPipeline().ingestRealData({ sources: ['supreme-court'] })\"",
    "ingest:high-courts": "node -e \"const DataIngestionPipeline = require('./scripts/data-ingestion-pipeline'); new DataIngestionPipeline().ingestRealData({ sources: ['high-court'] })\"",
    "ingest:all": "node -e \"const DataIngestionPipeline = require('./scripts/data-ingestion-pipeline'); new DataIngestionPipeline().ingestRealData({ sources: ['ecourt', 'supreme-court', 'high-court', 'indian-kanoon'] })\""
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.1",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "pino": "^8.16.1",
    "pino-pretty": "^10.2.3",
    "redis": "^4.6.12"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.9.0",
    "@pinecone-database/pinecone": "^2.0.0",
    "chromadb": "^1.4.0",
    "google-generativeai": "^0.3.0",
    "openai": "^4.24.0",
    "weaviate-client": "^1.1.0"
  },
  "keywords": [
    "legal-ai",
    "rag",
    "indian-law",
    "nlp",
    "retrieval-augmented-generation",
    "nyaysetu"
  ],
  "author": "NyaySetu Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  }
}
